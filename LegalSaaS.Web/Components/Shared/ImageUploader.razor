@using Microsoft.AspNetCore.Components.Forms
@inject LegalSaaS.Web.Services.IFileStorageService Storage

<InputFile class="form-control" OnChange="HandleFileSelected" />

@if (!string.IsNullOrWhiteSpace(imageUrl))
{
    <div class="mt-3">
        <img src="@imageUrl" style="max-width:220px;border-radius:12px;" />
    </div>
}

@code {
    [Parameter] public string Folder { get; set; } = "general";
    [Parameter] public EventCallback<string> OnUploaded { get; set; }

    private string? imageUrl;

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        imageUrl = await Storage.SaveImageAsync(file, Folder);
        await OnUploaded.InvokeAsync(imageUrl);
    }
}